# yournewhandle — environment variables
#
# Vercel Upstash integration (auto-provisioned) provides:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
# KV_URL=
# REDIS_URL=
#
# Manual Upstash (alternative naming, also supported):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
#
# Optional — raises GitHub API rate limit on server route:
# GITHUB_TOKEN=
#
# Optional — Gemini AI handle studio on /api/polish-handle:
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
#
# Recommended for production — Reddit blocks unauthenticated datacenter checks.
# Create a script app at https://www.reddit.com/prefs/apps (type: script).
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
#
# Optional — Last.fm Audioscrobbler API (defaults to Last.fm web client key):
# LASTFM_API_KEY=
# Optional — paid API keys (secret:plan[:label], comma-separated):
# YNH_API_KEYS=ynh_live_abc123:pro:Production,ynh_live_def456:starter:Dev
#
# Stripe + site — fill in .env.local (see .env.example):
# NEXT_PUBLIC_SITE_URL=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_BILLING_PORTAL_CONFIGURATION=
# STRIPE_PRODUCT_STARTER=
# STRIPE_PRICE_STARTER=
# STRIPE_PRODUCT_PRO=
# STRIPE_PRICE_PRO=
# STRIPE_PRODUCT_ENTERPRISE=
# STRIPE_PRICE_ENTERPRISE_BASE=
# STRIPE_PRICE_ENTERPRISE=
# STRIPE_METER_ID=
# STRIPE_METER_EVENT_NAME=api_request
#
# TELEGRAM_BOT_TOKEN=
# HUNTER_API_KEY=
# SERPAPI_KEY=
