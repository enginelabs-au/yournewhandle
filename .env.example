# yournewhandle — environment variables
#
# Vercel Upstash integration (auto-provisioned) provides:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
# KV_URL=
# REDIS_URL=
#
# Manual Upstash (alternative naming, also supported):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
#
# Optional — raises GitHub API rate limit on server route:
# GITHUB_TOKEN=
#
# Optional — Gemini AI handle studio on /api/polish-handle:
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
#
# Optional — Reddit username checks (oauth.reddit.com when RSS is rate-limited):
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
#
# Optional — paid API keys (secret:plan[:label], comma-separated):
# YNH_API_KEYS=ynh_live_abc123:pro:Production,ynh_live_def456:starter:Dev
#
# Stripe Checkout + API billing (see docs/stripe-env.reference.md for product/price IDs):
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_BILLING_PORTAL_CONFIGURATION=
# STRIPE_PRICE_STARTER=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_ENTERPRISE=
# STRIPE_METER_ID=
# STRIPE_METER_EVENT_NAME=api_request
# NEXT_PUBLIC_SITE_URL=https://yournewhandle.com
#
# TELEGRAM_BOT_TOKEN=
# HUNTER_API_KEY=
# SERPAPI_KEY=
